extends layout

block content
  h1= title

  form(id='CostumeForm', action='/resource/costumes', method='POST')
    div.form-group
      label(class='costumeAttr', for='costume_type') Costume type
      input(type='text', name='costume_type', required)

    div.form-group
      label(class='costumeAttr', for='size') Costume size
      input(type='text', name='size', required)

    div.form-group
      label(class='costumeAttr', for='cost') Costume cost
      input(type='number', name='cost', required)

    input(type='submit')

  script.
    document.forms['CostumeForm'].addEventListener('submit', (event) => {
      event.preventDefault();
      fetch(event.target.action, {
        method: 'POST',
        body: new URLSearchParams(new FormData(event.target))
      })
      .then(resp => resp.json())
      .then(body => {
        alert("Save succeeded");
      })
      .catch(error => {
        alert("Save failed " + error);
      });
    });