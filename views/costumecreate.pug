extends layout

block content
  h1= title

  form(action='/resource/costumes', method='POST')
    div.form-group
      label(for='costume_type') Costume type
      input(type='text', name='costume_type', required)

    div.form-group
      label(for='size') Costume size
      input(type='text', name='size', required)

    div.form-group
      label(for='cost') Costume cost
      input(type='number', name='cost', required)

    input(type='submit')